{
    "batching": {
        "batch_size": 32,
        "diverse": false,
        "max_tokens": 1024,
        "sampling_smoothing": 1,
        "shuffle": true,
        "sort_by_size": true
    },
    "decoders": {
        "classification": {},
        "default_decoder": {},
        "dependency": {},
        "mlm": {},
        "multiclas": {},
        "multiseq": {},
        "probdistr": {},
        "regression": {},
        "seq": {},
        "seq_bio": {},
        "string2string": {},
        "tok": {}
    },
    "default_dec_dataset_embeds_dim": 12,
    "encoder": {
        "dropout": 0.2,
        "max_input_length": 128,
        "update_weights_encoder": true
    },
    "reset_transformer_model": false,
    "training": {
        "keep_top_n": 1,
        "learning_rate_scheduler": {
            "cut_frac": 0.3,
            "decay_factor": 0.38,
            "discriminative_fine_tuning": true,
            "gradual_unfreezing": true
        },
        "num_epochs": 20,
        "optimizer": {
            "betas": [
                0.9,
                0.99
            ],
            "lr": 0.0001,
            "weight_decay": 0.01
        }
    },
    "transformer_model": "roberta-base",
    "random_seed": 8446
}